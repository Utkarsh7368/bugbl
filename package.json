{
  "name": "bugbl-io",
  "version": "1.0.0",
  "description": "Real-time multiplayer drawing & guessing game for developers",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npm run dev",
    "preinstall": "cd server && npm install",
    "build": "echo 'Railway: Root install complete'",
    "start": "node server/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
